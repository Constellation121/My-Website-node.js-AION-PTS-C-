<div class="container">
    <h1>Account successfully created!</h1>
    <p><b>User:</b> <span id="user"><%= username %></span></p>
    <p><b>Password generated:</b> <span id="pass"><%= password %></span></p>

    
    <br>
        <h3>
           Don't forget to download the PDF with your information.!<br>
         </h3>
    <button onclick="downloadPDF()">account_credentials_xxxxxxxxx Aion 5.8.PDF</button>
</div>

<script>
    async function downloadPDF() {
        const { jsPDF } = window.jspdf;
        const doc = new jsPDF();

        doc.setFillColor(15, 15, 25);
        doc.rect(0, 0, 210, 297, "F");


        doc.setDrawColor(180, 40, 255);
        doc.setLineWidth(2);
        doc.rect(10, 10, 190, 277);


        doc.setFont("helvetica", "bold");
        doc.setFontSize(26);
        doc.setTextColor(255, 80, 80);
        doc.text("Account Credentials", 105, 50, { align: "center" });


        doc.setFontSize(14);
        doc.setTextColor(240, 240, 240);
        const user = document.getElementById("user").textContent;
        const pass = document.getElementById("pass").textContent;
        doc.text(`User: ${user}`, 30, 100);
        doc.text(`Password: ${pass}`, 30, 120);


        doc.setDrawColor(120, 40, 200);
        doc.line(20, 140, 190, 140);


        doc.setFontSize(10);
        doc.setTextColor(180, 180, 200);
        doc.text("Generated by Atreia.Dev -Edition", 105, 280, { align: "center" });

  
        doc.save("account_credentials_xxxxxxxxx Aion 5.8.pdf");
    }
</script>
