<!DOCTYPE html>

<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Account Created</title>


    <link rel="icon" type="image/png" sizes="32x32" href="img/xxxxxxxxx.png">
    <link rel="icon" type="image/png" sizes="16x16" href="img/xxxxxxxxx.png">
    <link rel="stylesheet" href="/style.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: #fff;
            min-height: 100vh;
            margin: 0;
            position: relative;
            background-color: #0d0d1a;
            overflow-x: hidden;
        }

    #bgVideo {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: 0;
    }

    body::before {
        content: "";
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(120deg, rgba(0,0,0,0.85), rgba(120,40,150,0.3), rgba(0,0,0,0.85));
        background-size: 400% 400%;
        animation: gradientShift 18s ease infinite;
        z-index: 1;
    }

    @keyframes gradientShift {
        0% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
        100% { background-position: 0% 50%; }
    }

    .container {
        position: relative;
        z-index: 2;
        background: rgba(20, 20, 40, 0.8);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        padding: 30px;
        border-radius: 14px;
        width: 420px;
        margin: 100px auto;
        text-align: center;
        border: 1px solid rgba(120, 60, 150, 0.6);
        box-shadow: 0 0 25px rgba(120, 40, 150, 0.7);
        animation: fadeIn 1.2s ease;
    }

    h1 {
        font-size: 26px;
        font-weight: 600;
        color: #ff5c5c;
        text-shadow: 0 0 10px rgba(255, 100, 120, 0.7), 0 0 20px rgba(120,40,150,0.7);
        margin-bottom: 15px;
    }

    p {
        font-size: 18px;
        margin: 8px 0;
        color: #eee;
    }

    a, button {
        display: inline-block;
        margin-top: 20px;
        padding: 12px 20px;
        border-radius: 8px;
        background: linear-gradient(90deg, #ff5c5c, #c24cff);
        color: #fff;
        font-weight: bold;
        text-transform: uppercase;
        text-decoration: none;
        transition: transform 0.2s, box-shadow 0.3s;
        cursor: pointer;
        border: none;
    }

    a:hover, button:hover {
        transform: translateY(-2px);
        box-shadow: 0 0 20px #ff5c5c, 0 0 30px #c24cff;
    }
</style>
