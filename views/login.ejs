<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Eternal Abyss Login</title>

  <link rel="icon" type="image/png" sizes="32x32" href="/img/">
  <link rel="icon" type="image/png" sizes="16x16" href="/img/">

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body {
      margin: 0;
      padding: 0;
      font-family: 'Poppins', sans-serif;
      color: #fff;
      overflow-x: hidden;
      background-color: #0c0c0c;
    }

    .video-background {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      z-index: -2;
      opacity: 0.45;
    }

    .particles {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: -1;
      overflow: hidden;
    }

    .particle {
      position: absolute;
      width: 5px;
      height: 5px;
      background: radial-gradient(circle, rgba(0,153,255,0.8), rgba(255,255,255,0));
      border-radius: 50%;
      animation: float 10s linear infinite;
    }

    @keyframes float {
      0% { transform: translateY(0) scale(1); opacity: 1; }
      100% { transform: translateY(-120vh) scale(0.5); opacity: 0; }
    }

    .container-login {
      position: fixed;
      top: 50%;
      right: 750px;
      transform: translateY(-50%);
      background: rgba(0, 0, 0, 0.75);
      padding: 40px;
      border-radius: 52px;
      width: 340px;
      box-shadow: 0 0 60px rgba(0,0,0,0.7);
      z-index: 10;
      text-align: center;
    }

    .container-login h1 {
      margin-bottom: 20px;
      color: #a4c2ce;
      font-weight: 600;
    }

    .container-login input {
      display: block;
      width: 90%;
      margin: 10px auto;
      padding: 10px;
      border-radius: 8px;
      border: none;
      outline: none;
      background-color: rgba(20,20,20,0.9);
      color: #fff;
    }

    .container-login button {
      margin-top: 15px;
      padding: 12px;
      width: 95%;
      border: none;
      border-radius: 6px;
      background: #a4c2ce;
      color: #fff;
      font-weight: bold;
      cursor: pointer;
    }

    .recaptcha-container {
      display: flex;
      justify-content: center;
      transform: scale(0.85);
      margin-top: 15px;
    }

    .erro-msg {
      background: #660000aa;
      padding: 10px;
      border-radius: 6px;
      margin-bottom: 10px;
      color: #ffbaba;
      font-weight: bold;
    }
  </style>
</head>

<body>

  <!-- 🔹 Background Video -->
  <video autoplay muted loop playsinline class="video-background">
    <source src="/img/bg_main_0722.mp4" type="video/mp4">
  </video>

  <!-- 🔹 Particles -->
  <div class="particles"></div>

  <!-- 🔹 Login Form -->
  <div class="container-login">

      <h1>Login</h1>

      <% if (erro) { %>
        <div class="erro-msg"><%= erro %></div>
      <% } %>

      <form action="/login" method="POST">

        <input type="text" name="username" placeholder="Username" required>

        <input type="password" name="password" placeholder="Password" required>

        <!-- CAPTCHA (offline) -->
        <div class="recaptcha-container">
          <div class="g-recaptcha" data-sitekey="6LdosAssAAAAAM6H4IrgfWyX02BjJLOYNvG7yqdK"></div>
        </div>

        <button type="submit">Login</button>

      </form>

      <a href="/">Back</a>
  </div>

  <script src="https://www.google.com/recaptcha/api.js"></script>

  <script>
    const particleContainer = document.querySelector('.particles');
    const numParticles = 60;

    for(let i = 0; i < numParticles; i++){
      const particle = document.createElement('div');
      particle.classList.add('particle');
      particle.style.left = Math.random() * 100 + 'vw';
      particle.style.top = Math.random() * 100 + 'vh';
      particle.style.animationDuration = 8 + Math.random() * 6 + 's';
      particleContainer.appendChild(particle);
    }
  </script>

</body>
</html>