<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>xxxxxx</title>

  <link rel="icon" type="image/png" href="img/xxxx">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body {
      margin: 0;
      font-family: 'Poppins', sans-serif;
      color: #fff;
      background: #0c0c0c;
      padding-top: 75px;
    }

    .top-nav {
      position: fixed;
      top: 0;
      width: 100%;
      padding: 10px 25px;
      display: flex;
      justify-content: space-between;
      background: rgba(0,0,0,0.6);
      z-index: 100;
    }

    .container-cadastro {
      position: fixed;
      top: 20%;
      right: 30px;
      background: rgba(0,0,0,0.85);
      padding: 30px;
      border-radius: 20px;
      width: 320px;
      text-align: center;
    }

    input {
      width: 100%;
      padding: 10px;
      margin-bottom: 15px;
      border-radius: 8px;
      border: none;
    }

    button {
      width: 100%;
      padding: 10px;
      border: none;
      border-radius: 8px;
      background: #b7ceec;
      color: #000;
      font-weight: bold;
      cursor: pointer;
    }

    .g-recaptcha {
      margin: 15px 0;
      transform: scale(0.9);
      transform-origin: left;
    }
  </style>
</head>

<body>

<!-- NAV -->
<div class="top-nav">
  <div>xxxxxxx</div>
  <div id="serverOnline"></div>
</div>

<!-- FORM -->
<div class="container-cadastro">

  <button id="showFormBtn">Create Account</button>

  <form id="createForm" action="/criar" method="POST" style="display:none;" onsubmit="return validarCaptcha();">

    <input type="text" name="username" placeholder="User" required>

    <!-- CAPTCHA -->
    <div class="g-recaptcha"
         data-sitekey="6LfX8ZMsAAAAAODEw697vCPB5xWFV5ZgJUcCfmP2">
    </div>

    <button type="submit">Confirm Create</button>

    <h4 style="margin-top:10px;">
      Password will be generated automatically
    </h4>

  </form>

</div>

<!-- CAPTCHA SCRIPT -->
<script src="https://www.google.com/recaptcha/api.js" async defer></script>

<script>
  // Show form
  document.getElementById("showFormBtn").onclick = function() {
    this.style.display = "none";
    document.getElementById("createForm").style.display = "block";
  };

  // VALIDATE CAPTCHA
  function validarCaptcha() {
    var response = grecaptcha.getResponse();

    if (response.length === 0) {
      alert("❌ Please confirm the CAPTCHA!");
      return false;
    }

    return true;
  }

  // ONLINE TIME
  (function () {
    const start = new Date("2026-01-28T18:00:00");

    function update() {
      const now = new Date();
      const diff = now - start;
      const days = Math.floor(diff / (1000 * 60 * 60 * 24));

      document.getElementById("serverOnline").innerHTML =
        "Online: " + days + " days";
    }

    update();
    setInterval(update, 60000);
  })();
</script>

</body>
</html>